# Optional local ficta config example.
# Prefer `ficta setup` for ~/.ficta/config.env. Env vars are one-off overrides.
# Do not commit real secrets.

# Common overrides
# FICTA_REQUIRE_REGISTRY=1
# FICTA_REDACT_PATHS=1
# FICTA_LOG_BODIES=0

# Registry sources
# FICTA_REGISTRY_ENV_FILE_ENABLED=1
# FICTA_REGISTRY_ENV_FILE_PATHS=.env:.env.local
# FICTA_REGISTRY_DOPPLER_ENABLED=1
# FICTA_REGISTRY_DOPPLER_CONFIGS=current
# FICTA_REGISTRY_DOPPLER_PROJECT=
# FICTA_REGISTRY_PROCESS_ENV_ENABLED=1
# FICTA_REGISTRY_PROCESS_ENV_MODE=secret-ish
# FICTA_REGISTRY_MIN_LEN=8

# Runtime / diagnostics
# FICTA_PORT=8787
# FICTA_LOG_DIR=~/.ficta/logs
# FICTA_QUIET=0
# FICTA_FAIL_CLOSED=1
# FICTA_ANTHROPIC_UPSTREAM=https://api.anthropic.com
# FICTA_OPENAI_UPSTREAM=https://api.openai.com
# FICTA_CHATGPT_UPSTREAM=https://chatgpt.com
